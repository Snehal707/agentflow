{
  "name": "agentflow",
  "version": "0.1.0",
  "private": true,
  "description": "AgentFlow — Autonomous AI agents. Instant payments. Zero gas. Arc Testnet + Circle x402.",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx server.ts",
    "start:api": "cross-env NODE_ENV=production EMBEDDED_AGENT_SERVERS=false tsx server.ts",
    "dev:agents": "cross-env NODE_ENV=production concurrently -n f,r,a,w,sw,v,br,po,inv,vis,tr -c blue,green,yellow,magenta,red,white,gray,black,cyan,cyan,blue \"tsx facilitator/server.ts\" \"tsx agents/research/server.ts\" \"tsx agents/analyst/server.ts\" \"tsx agents/writer/server.ts\" \"tsx agents/swap/server.ts\" \"tsx agents/vault/server.ts\" \"tsx agents/bridge/server.ts\" \"tsx agents/portfolio/server.ts\" \"tsx agents/invoice/server.ts\" \"tsx agents/vision/server.ts\" \"tsx agents/transcribe/server.ts\"",
    "setup": "node scripts/setup.js",
    "setup:ps": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "build": "echo \"Skipping compile step (runtime uses tsx server.ts)\"",
    "typecheck": "tsc --noEmit",
    "dev:facilitator": "tsx facilitator/server.ts",
    "dev:research": "tsx agents/research/server.ts",
    "dev:analyst": "tsx agents/analyst/server.ts",
    "dev:writer": "tsx agents/writer/server.ts",
    "dev:swap": "tsx agents/swap/server.ts",
    "dev:vault": "tsx agents/vault/server.ts",
    "dev:schedule": "tsx agents/schedule/server.ts",
    "dev:split": "tsx agents/split/server.ts",
    "dev:batch": "tsx agents/batch/server.ts",
    "dev:bridge": "tsx agents/bridge/server.ts",
    "dev:portfolio": "tsx agents/portfolio/server.ts",
    "dev:invoice": "tsx agents/invoice/server.ts",
    "dev:vision": "tsx agents/vision/server.ts",
    "dev:transcribe": "tsx agents/transcribe/server.ts",
    "dev:frontend": "npm run serve:stable --prefix agentflow-frontend",
    "dev:frontend:hot": "npm run dev --prefix agentflow-frontend",
    "dev:bot": "tsx lib/telegram-bot.ts",
    "dev:hermes": "node scripts/start-hermes.js",
    "dev:stack": "node scripts/start-dev-stack.js",
    "diagnose:gateway-dcw": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/diagnose-gateway-dcw-logs.ps1",
    "diagnose:gateway-dcw:trigger": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/diagnose-gateway-dcw-logs.ps1 -TriggerResearchRun",
    "dev:orchestrator": "tsx orchestrator/index.ts",
    "script:deposit": "tsx scripts/deposit.ts",
    "deposit:agent-gateway": "tsx --env-file=.env scripts/deposit-agent-gateway.ts",
    "script:check-balances": "tsx scripts/check-balances.ts",
    "script:pre-launch": "tsx scripts/pre-launch-checks.ts",
    "script:setup-circle": "tsx scripts/setup-circle.ts",
    "script:bootstrap": "tsx scripts/bootstrap.ts",
    "script:mint-identity": "tsx scripts/mint-identity.ts",
    "script:create-missing-wallets": "tsx scripts/create-missing-wallets.ts",
    "script:seed-funds": "tsx scripts/seed-funds.ts",
    "script:test-usyc": "tsx --env-file=.env scripts/test-usyc.ts",
    "script:generate-demo-txs": "tsx --env-file=.env scripts/generate-demo-txs.ts",
    "fund:agent-wallets": "tsx --env-file=.env scripts/fund-agent-wallets.ts",
    "script:probe-a2a": "tsx --env-file=.env scripts/probe-a2a-transactions.ts",
    "script:probe-x402-attempt": "tsx --env-file=.env scripts/probe-x402-attempt.ts",
    "script:self-test-a2a-scheduler": "tsx scripts/self-test-a2a-chat-scheduler.ts",
    "script:verify-a2a-preconditions": "tsx --env-file=.env scripts/verify-a2a-preconditions.ts",
    "script:run-a2a-three-tests": "tsx --env-file=.env scripts/run-a2a-three-user-tests.ts",
    "proof:a2a": "tsx --env-file=.env scripts/proof-a2a-demo.ts",
    "script:verify-funds-smoke": "tsx --env-file=.env scripts/verify-funds-smoke.ts",
    "script:verify-agents": "tsx --env-file=.env scripts/verify-agent.ts",
    "script:withdraw-old-liquidity": "tsx scripts/withdraw-old-liquidity.ts",
    "contract:deploy-agentpay-registry": "hardhat run hardhat-scripts/deploy-agentpay-registry.ts --network arcTestnet",
    "gen:seller-address": "node -e \"const { privateKeyToAccount } = require('viem/accounts'); const pk = '0x' + require('crypto').randomBytes(32).toString('hex'); const a = privateKeyToAccount(pk); console.log('Add to .env:\\nSELLER_ADDRESS=' + a.address);\"",
    "cron:worker": "tsx crons/index.ts",
    "treasury:topup": "tsx --env-file=.env -e \"import { runTreasuryTopUp } from './lib/agent-treasury'; runTreasuryTopUp().then(() => process.exit(0))\"",
    "lint": "echo \"No linter configured\""
  },
  "keywords": [
    "circle",
    "x402",
    "gateway",
    "micropayments",
    "usdc"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@circle-fin/adapter-circle-wallets": "^1.2.6",
    "@circle-fin/adapter-viem-v2": "^1.8.2",
    "@circle-fin/app-kit": "^1.4.1",
    "@circle-fin/bridge-kit": "^1.7.0",
    "@circle-fin/developer-controlled-wallets": "^10.2.0",
    "@circlefin/x402-batching": "latest",
    "@mendable/firecrawl-js": "^1.21.1",
    "@openzeppelin/contracts": "^4.9.6",
    "@supabase/supabase-js": "^2.100.0",
    "@x402/core": "^2.3.0",
    "@x402/evm": "^2.5.0",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.83.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "svix": "^1.89.0",
    "tsx": "^4.0.0",
    "viem": "^2.47.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/chai": "^4.3.20",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "hardhat": "^2.28.6",
    "typescript": "^5.7.3"
  }
}
