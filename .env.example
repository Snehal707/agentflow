CLOUDSMITH_TOKEN=your_cloudsmith_token
HERMES_API_KEY=your_hermes_api_key
HERMES_BASE_URL=https://your-hermes-endpoint
HERMES_MODEL=Hermes-4-405B
HERMES_VISION_MODEL=google/gemma-4-26b-a4b-it
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PORT=4000

# Hermes tools: must match hermes-brain AGENTFLOW_BRAIN_INTERNAL_KEY for agentpay_request and /api/pay/schedule
AGENTFLOW_BRAIN_INTERNAL_KEY=

# --- Internal admin panels (/internal/review|memory|feedback) ---
# Two independent layers protect these:
#   1) WALLET ALLOWLIST (guards the DATA, backend): only these wallets can load
#      admin APIs. Required in production.
INTERNAL_ADMIN_WALLETS=0xAdminWallet1,0xAdminWallet2
#   2) PANEL KEY (hides the PAGES from the public, frontend middleware): in
#      production the /internal/* pages 404 unless unlocked with this secret via
#      `https://yourapp/internal/memory?key=THE_KEY` (sets an httpOnly cookie).
#      Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INTERNAL_PANEL_KEY=
#   Needed so the /api/internal/* proxy routes are live (else they 404 for everyone).
INTERNAL_MEMORY_MONITOR_ENABLED=true
#   Local-dev convenience ONLY — loopback requests skip the wallet check.
#   MUST be false/unset in production (the same-host frontend proxy can otherwise
#   make public requests look like loopback).
INTERNAL_ADMIN_BYPASS_LOCAL=false

# Optional: verbose x402 / Circle / A2A server logs (development only; omit in production)
# AGENTFLOW_X402_DEBUG=true
# AGENTFLOW_CIRCLE_DEBUG=true
# AGENTFLOW_A2A_DEBUG=true

# Optional: `/api/chat/respond` brain session continuity (history counts, YES/research defer keys)
# AGENTFLOW_CHAT_SESSION_TRACE=true

# Optional: SSE chat stream instrumentation (Hermes/runAgentBrain path). Logs keys like chat_stream_* to console when true (development only; omit in production).
# AGENTFLOW_CHAT_SSE_DEBUG=true

# Default conversational replies use Hermes (see lib/agent-brain.ts). Smoke: GET AGENTFLOW_HERMES_URL/health (often http://127.0.0.1:8000/health). Align AGENTFLOW_HERMES_URL and HERMES_* with hermes gateway.

# Circle Developer-Controlled Wallets (AgentFlow Phase 2)
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_ENTITY_SECRET=your_entity_secret
# Optional: set after first run if not created manually
CIRCLE_WALLET_SET_ID=your_wallet_set_id

# Required for seller payout routing (x402 payTo address)
SELLER_ADDRESS=0xYOUR_SELLER_ADDRESS

# Optional fallback only for deriving SELLER_ADDRESS when missing.
# No backend buyer signing is done with this key anymore.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Telegram execution bot (polling — run `npm run dev:bot`)
TELEGRAM_BOT_TOKEN=
# Bot @username without @ — used by API for /api/settings Telegram links (same as in Telegram)
TELEGRAM_BOT_USERNAME=
# Optional secret for stateless Telegram link codes. Falls back to JWT_SECRET if omitted.
TELEGRAM_LINK_SECRET=
# Public bot username for t.me links (frontend)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=AgentFlowBot
# Site URL for link instructions
APP_BASE_URL=https://agentflow.one
# Optional: embed bot in API process (not recommended; prefer dev:bot)
# RUN_TELEGRAM_BOT=true
# If another process already polls this bot (e.g. prod, second dev machine), set to avoid Telegram 409 Conflict:
# SKIP_TELEGRAM_BOT=true

# Optional overrides
RESEARCH_AGENT_PRICE=0.005
ANALYST_AGENT_PRICE=0.003
WRITER_AGENT_PRICE=0.008
VISION_AGENT_PRICE=0.004
TRANSCRIBE_AGENT_PRICE=0.002
# Deep mode runs brief generation, hybrid retrieval, claim extraction, verification, and synthesis.
DEEP_RESEARCH_TIMEOUT_MS=420000
# Keep paid agent HTTP calls open long enough for deep research responses.
X402_AGENT_RESPONSE_TIMEOUT_MS=600000
# Optional legacy escape hatch. Leave unset/false in production: Firecrawl is used for targeted scraping, not DDG-backed search.
# AGENTFLOW_ENABLE_FIRECRAWL_SEARCH=false
# Optional. Required for FRED economic data. Get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Optional. Required for BEA economic data API. Get free key/UserID at https://apps.bea.gov/API/signup/
BEA_Data_API=
UN_COMTRADE_API_KEY=
UN_COMTRADE_SECONDARY_KEY=
Alpha_Vantage_API_KEY=
Finnhub_API_KEY=
Twelve_Data_API_KEY=
FMP_API_KEY=
# Optional. Required for Congress.gov legislative data. Get free key at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=
# Optional. Required for The Guardian content API. Get free key at https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=
# Optional. Required for US Census API data in the current registry endpoint. Get free key at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# Optional. Required for The Graph gateway/subgraph APIs. Current generic adapter does not yet support GraphQL body queries.
THE_GRAPH_API_KEY=
# Optional crypto/Web3 source keys. Add only when the matching source is enabled/wired.
CMC_API_KEY=
CRYPTOCOMPARE_API_KEY=
LIVECOINWATCH_API_KEY=
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
SOLSCAN_API_KEY=
SUBSCAN_API_KEY=
DAPPRADAR_API_KEY=
SANTIMENT_API_KEY=
LUNARCRUSH_API_KEY=
WHALE_ALERT_API_KEY=
OPENSEA_API_KEY=
TOKENINSIGHT_API_KEY=
NFTGO_API_KEY=
RESERVOIR_API_KEY=
# Optional. Required for NASA ADS bibliographic search. Get token from ADS account settings.
NASA_ADS_API_KEY=
# Optional. Required for EIA energy data API. Get free key at https://www.eia.gov/opendata/
EIA_API_KEY=
# Optional legacy NOAA CDO v2 token. Current registry uses newer no-key NCEI Access Services endpoints.
NOAA_CDO_API_KEY=
# Optional weather/media APIs that were verified as key-gated or not currently enabled in the registry.
GOVINFO_API_KEY=
OPENWEATHERMAP_API_KEY=
WAQI_API_KEY=
TMDB_API_KEY=
OMDB_API_KEY=
TVMAZE_API_KEY=
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=
DISCOGS_API_KEY=
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
# Preferred for Discogs database search. Generate under Discogs developer settings as a personal access token.
DISCOGS_USER_TOKEN=
# Optional. Required for eBird API 2.0. Generate a free key at https://ebird.org/api/keygen
EBIRD_API_KEY=
# Optional. Required for ReliefWeb API v2 after 2025-11-01. This is a pre-approved app name, not a secret key.
RELIEFWEB_APPNAME=
# Optional. Required for Materials Project API. Get key at https://materialsproject.org/api
MATERIALS_PROJECT_API_KEY=
# Optional. Required for RSC ChemSpider API.
CHEMSPIDER_API_KEY=
# Optional. Required for Libraries.io dependency/package metadata API.
LIBRARIES_IO_API_KEY=
# Optional. Required for NHS Website Content API v2. The key must be associated with the Website Content API product in the NHS developer portal.
NHS_API_KEY=
# Optional NHS app credentials for APIs that require app-level auth. NHS Website Content API v2 only uses NHS_API_KEY.
NHS_SECRET_KEY=
NHS_APPLICATION_ID=
# Optional. Required for WTO Stats API. Primary key is used; secondary key is for rotation.
WTO_API_KEY=
WTO_SECONDARY_KEY=
# Optional. Required for api.data.gov-backed APIs such as Regulations.gov.
API_DATA_GOV_KEY=
# Optional. Required only for analytics.usa.gov API usage; not used by Regulations.gov.
ANALYTICS_USA_GOV_API_KEY=
AGENT_TIMEOUT_MS=80000
VISION_AGENT_PORT=3016
TRANSCRIBE_AGENT_PORT=3017
BRIDGE_AGENT_PORT=3021
PREDMARKET_AGENT_PORT=3013
SPLIT_AGENT_PORT=3019
SPLIT_AGENT_PRICE=0.005
# x402 facilitator: API, payProtectedResourceServer preflight, and all paid agents resolve the same base URL via lib/facilitator-url.ts (getFacilitatorBaseUrl). Set FACILITATOR_URL to the full base (no trailing slash), or set FACILITATOR_PORT only (defaults to 3000 if both unset — must match the running facilitator).
# FACILITATOR_URL=http://127.0.0.1:3010
FACILITATOR_PORT=3010
VISION_AGENT_URL=http://localhost:3016
TRANSCRIBE_AGENT_URL=http://localhost:3017
# Agent Store / health checks (optional overrides; defaults match api/marketplace.ts)
ANALYST_AGENT_URL=http://localhost:3002
WRITER_AGENT_URL=http://localhost:3003
RESEARCH_AGENT_URL=http://localhost:3001
BRIDGE_AGENT_URL=http://localhost:3021
PREDMARKET_AGENT_URL=http://localhost:3013
SCHEDULE_AGENT_URL=http://localhost:3018
SPLIT_AGENT_URL=http://localhost:3019
BATCH_AGENT_URL=http://localhost:3020
SCHEDULE_AGENT_PRICE=0.003
BATCH_AGENT_PRICE=0.01
PREDMARKET_AGENT_PRICE=0.012
VISION_DAILY_LIMIT=5
TRANSCRIBE_DAILY_LIMIT=50
INTENT_ROUTER_ENABLED=false
AGENT_JSON_LIMIT=20mb

# Demo USDC transfers (scripts/generate-demo-txs.ts) — payer EOA must have AgentFlow user-agent wallet funded
TEST_WALLET_ADDRESS=
DEMO_RECIPIENT_1=
DEMO_RECIPIENT_2=

# Arc / Foundry-deployed contracts (set after `forge create` — see foundry/README.md)
# AGENTFLOW_REGISTRY_ADDRESS=0x
# SWAP_CONTRACT_ADDRESS=0x
# VAULT_CONTRACT_ADDRESS=0x
# AgentPay on-chain .arc registry (deploy: npm run contract:deploy-agentpay-registry; needs TREASURY_WALLET_ADDRESS)
# AGENTPAY_REGISTRY_ADDRESS=0x
# TREASURY_WALLET_ADDRESS=0x

PAY_PER_TASK_DAILY_LIMIT=200
PAY_PER_TASK_MINUTE_LIMIT=10
# PAY_PER_TASK_MAX_TX_USDC=250
# SWAP_PAIR_TOKEN_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
# scripts/add-liquidity.ts: human amounts (6 decimals). Default swap seed 150000/150000; vault deposit 10 USDC.
# ADD_LIQUIDITY_SWAP_AMOUNT=150000
# VAULT_DEPOSIT_AMOUNT=10
# Swap safety (optional): block bad quotes before execution
# SWAP_MAX_PRICE_IMPACT_PCT=15
# Tight 1:1 stable bands
# SWAP_SANITY_USDC_USDT_MIN=0.95
# SWAP_SANITY_USDC_USDT_MAX=1.05
# SWAP_SANITY_USDC_DAI_MIN=0.95
# SWAP_SANITY_USDC_DAI_MAX=1.05
# Wider forex-aware band for USDC/EURC on testnet
# SWAP_SANITY_USDC_EURC_MIN=0.80
# SWAP_SANITY_USDC_EURC_MAX=1.20
# Fallback band for unknown stable/stable pairs
# SWAP_SANITY_DEFAULT_MIN=0.85
# SWAP_SANITY_DEFAULT_MAX=1.15
# Optional comma-separated allowlist of Lunex pool/router addresses. Swaps refuse
# to sign if Lunex returns a different target contract.
LUNEX_POOL_WHITELIST=0xC24BFc8e4b10500a72A63Bec98CCC989CbDA41d8
# Lunex CCTP bridge uses the same Lunex API base URL + API key as swaps.
# No additional bridge env vars are required.
AGENTFLOW_FEATURE_FUNDS=true
