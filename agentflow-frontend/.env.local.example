# Backend URL for SSE /run, gateway-balance, and deposit endpoints
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
# Restart `npm run dev` (Next) after changing NEXT_PUBLIC_BACKEND_URL — values are inlined at dev-server start.

# Optional: show correct @handle in the UI before the API responds (must match your real bot).
# The API also reads TELEGRAM_BOT_USERNAME from repo-root .env — set one or both.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Required for WalletConnect (OKX, Rainbow, etc.). Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Server-only: mic → /api/transcribe → OpenAI Audio (not exposed to the browser).
# You can set OPENAI_API_KEY here or in the repo root `../.env` / `../.env.local` (merged at dev time).
OPENAI_API_KEY=
# Optional; default is gpt-4o-mini-transcribe (see Audio “Create transcription” in API reference).
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Internal-only observability pages such as /internal/memory.
# Requires matching backend admin allowlist via repo-root INTERNAL_ADMIN_WALLETS.
# INTERNAL_MEMORY_MONITOR_ENABLED=true
# Optional localhost-only bypass for internal admin pages during development.
# Do not enable in production.
# INTERNAL_ADMIN_BYPASS_LOCAL=true
