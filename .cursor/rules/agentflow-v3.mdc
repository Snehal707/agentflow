## Supabase Pattern (Critical)

```typescript
// BACKEND — uses service_role, bypasses RLS
import { createClient } from '@supabase/supabase-js'
export const adminDb = createClient(
  process.env.SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!
)

// FRONTEND — uses anon key, respects RLS
export const clientDb = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!
)
```

## DCW Pattern (Critical — Prevents Wallet Loss)

```typescript
// ALWAYS check Supabase first before creating wallets
// NEVER store wallet state in files or runtime .env
async function getOrCreateAgentWallets(agentSlug: string) {
  const existing = await adminDb
    .from('wallets')
    .select('*')
    .eq('agent_slug', agentSlug)
    .eq('purpose', 'owner')
    .single()

  if (existing.data) return existing.data  // return from DB

  // Only create if not in DB
  const wallet = await circleClient.createWallets({...})
  await adminDb.from('wallets').insert([...])  // persist immediately
  return wallet
}
```

## LLM Routing Pattern

```typescript
// lib/hermes.ts
const models = {
  fast:     process.env.HERMES_MODEL_FAST!,   // hermes-4-70b
  deep:     process.env.HERMES_MODEL_DEEP!,   // hermes-4-405b
  vision:   "gpt-4o",                          // OpenAI (invoice images)
  fallback: "gpt-4o-mini"                      // OpenAI fallback
}

// Use fast for: extension queries, quick analysis
// Use deep for: research reports, portfolio analysis
// Use vision for: invoice PDF/image parsing only
// Stream ALL responses — never show blank spinner
```

