{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentFlow Source Registry",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "name",
      "baseUrl",
      "topics",
      "trust",
      "method",
      "cost",
      "speed",
      "priority",
      "enabled",
      "type",
      "freshness",
      "result_type",
      "authority",
      "rate_limit"
    ],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1
      },
      "baseUrl": {
        "type": "string",
        "minLength": 1
      },
      "endpoint": {
        "type": "string",
        "minLength": 1
      },
      "topics": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        },
        "uniqueItems": true
      },
      "trust": {
        "enum": ["high", "medium_high", "medium", "low_medium"]
      },
      "method": {
        "enum": ["official_api", "rss", "rss_plus_scrape", "scrape", "dataset"]
      },
      "cost": {
        "enum": ["low", "medium", "high"]
      },
      "speed": {
        "enum": ["fast", "medium", "slow"]
      },
      "priority": {
        "type": "number"
      },
      "enabled": {
        "type": "boolean"
      },
      "type": {
        "enum": ["api", "rss", "publisher", "dataset", "reference"]
      },
      "freshness": {
        "enum": ["live", "daily", "weekly", "monthly", "static"]
      },
      "result_type": {
        "enum": ["article", "metric", "dataset", "paper", "filing", "reference", "mixed"]
      },
      "authority": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "rate_limit": {
        "type": "object",
        "additionalProperties": false,
        "required": ["calls", "window_seconds"],
        "properties": {
          "calls": {
            "type": "integer",
            "minimum": 1
          },
          "window_seconds": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "requires_key": {
        "type": "boolean"
      },
      "key_env_var": {
        "type": "string",
        "minLength": 1
      },
      "feed_url": {
        "type": "string",
        "minLength": 1
      },
      "rssUrls": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        },
        "uniqueItems": true
      },
      "last_verified": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    },
    "allOf": [
      {
        "if": {
          "properties": {
            "requires_key": {
              "const": true
            }
          },
          "required": ["requires_key"]
        },
        "then": {
          "required": ["key_env_var"]
        }
      },
      {
        "if": {
          "properties": {
            "method": {
              "enum": ["rss", "rss_plus_scrape"]
            }
          },
          "required": ["method"]
        },
        "then": {
          "anyOf": [
            {
              "required": ["feed_url"]
            },
            {
              "required": ["rssUrls"]
            }
          ]
        }
      }
    ]
  }
}
